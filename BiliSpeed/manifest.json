{
  "manifest_version": 3,
  "name": "BiliSpeed",
  "version": "1.0",
  "description": "B站倍速增强工具",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.bilibili.com/*",
    "*://live.bilibili.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.bilibili.com/video/*",
        "*://*.bilibili.com/bangumi/*"
      ],
      "js": ["content-video.js"],
      "run_at": "document_end"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "BiliSpeed 设置"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}